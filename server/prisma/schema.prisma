generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["clientExtensions"]
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model virtual_aliases {
  id              Int             @id @default(autoincrement())
  domain_id       Int
  source          String          @db.VarChar(200)
  destination     String          @db.VarChar(1000)
  virtual_domains virtual_domains @relation(fields: [domain_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "virtual_aliases_ibfk_1")

  @@index([domain_id], map: "domain_id")
}

model virtual_domains {
  id              Int               @id @default(autoincrement())
  name            String            @unique @db.VarChar(100)
  active          Int               @default(1) @db.TinyInt
  virtual_aliases virtual_aliases[]
  virtual_users   virtual_users[]
}

model virtual_users {
  id              Int             @id @default(autoincrement())
  domain_id       Int             @default(0)
  email           String          @unique @db.VarChar(200)
  name            String          @default("") @db.VarChar(100)
  quota           Int             @default(1000) @db.Int
  active          Int             @default(1) @db.TinyInt
  password        String          @default("") @db.VarChar(106)
  bytes           BigInt          @default(0) @db.BigInt
  messages        Int             @default(0) @db.Int
  last_login      Int             @default(0) @db.Int
  created_time    Int             @default(0) @db.Int
  virtual_domains virtual_domains @relation(fields: [domain_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "virtual_users_ibfk_1")

  @@index([domain_id], map: "domain_id")
}
